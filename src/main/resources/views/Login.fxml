<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="540.0"
            prefWidth="820.0"
            style="-fx-background-color: #F3F6FA;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.paqueteria.controller.LoginController">

    <children>

        <!-- PANEL IZQUIERDO -->

        <VBox alignment="CENTER"
              prefWidth="330.0"
              spacing="16.0"
              style="-fx-background-color: #E7EFF8;
                     -fx-border-color: transparent #D9E3EF transparent transparent;
                     -fx-border-width: 0 1 0 0;"
              AnchorPane.topAnchor="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0">

            <padding>
                <Insets top="35.0"
                        right="35.0"
                        bottom="35.0"
                        left="35.0"/>
            </padding>

            <children>

                <Label text="SISTEMA DE"
                       style="-fx-text-fill: #496783;
                              -fx-font-weight: bold;">
                    <font>
                        <Font size="18.0"/>
                    </font>
                </Label>

                <Label text="PAQUETERÍA"
                       style="-fx-text-fill: #284A69;
                              -fx-font-weight: bold;">
                    <font>
                        <Font size="31.0"/>
                    </font>
                </Label>

                <Label text="Gestión segura y eficiente de envíos"
                       wrapText="true"
                       textAlignment="CENTER"
                       style="-fx-text-fill: #70869A;">
                    <font>
                        <Font size="14.0"/>
                    </font>
                </Label>

                <Separator prefWidth="220.0"
                           style="-fx-padding: 18 0 18 0;"/>

                <Label text="Rastrea tu paquete"
                       style="-fx-text-fill: #345A7A;
                              -fx-font-weight: bold;">
                    <font>
                        <Font size="18.0"/>
                    </font>
                </Label>

                <Label text="Ingresa el código de seguimiento para consultar el estado y recorrido de tu envío."
                       maxWidth="250.0"
                       wrapText="true"
                       textAlignment="CENTER"
                       style="-fx-text-fill: #70869A;">
                    <font>
                        <Font size="13.0"/>
                    </font>
                </Label>

                <TextField fx:id="txtCodigoSeguimiento"
                           maxWidth="250.0"
                           prefHeight="42.0"
                           promptText="Ejemplo: PK-4F3C6134"
                           style="-fx-background-color: #FFFFFF;
                                  -fx-background-radius: 9;
                                  -fx-border-color: #CAD7E5;
                                  -fx-border-radius: 9;
                                  -fx-padding: 0 14 0 14;
                                  -fx-font-size: 13px;"/>

                <Button fx:id="btnRastrear"
                        maxWidth="250.0"
                        prefHeight="42.0"
                        mnemonicParsing="false"
                        onAction="#rastrearPaquete"
                        text="Rastrear paquete"
                        style="-fx-background-color: #6C91B5;
                               -fx-background-radius: 9;
                               -fx-text-fill: white;
                               -fx-font-size: 14px;
                               -fx-font-weight: bold;
                               -fx-cursor: hand;"/>

            </children>

        </VBox>

        <!-- PANEL DERECHO -->

        <VBox alignment="CENTER"
              spacing="17.0"
              AnchorPane.topAnchor="0.0"
              AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="330.0"
              AnchorPane.rightAnchor="0.0">

            <padding>
                <Insets top="45.0"
                        right="65.0"
                        bottom="45.0"
                        left="65.0"/>
            </padding>

            <children>

                <Label text="Bienvenido"
                       style="-fx-text-fill: #263F57;
                              -fx-font-weight: bold;">
                    <font>
                        <Font size="29.0"/>
                    </font>
                </Label>

                <Label text="Inicia sesión para administrar el sistema"
                       style="-fx-text-fill: #7B8EA2;">
                    <font>
                        <Font size="14.0"/>
                    </font>
                </Label>

                <VBox maxWidth="340.0"
                      spacing="7.0"
                      style="-fx-padding: 20 0 0 0;">

                    <children>

                        <Label text="Usuario"
                               style="-fx-text-fill: #425D75;
                                      -fx-font-weight: bold;">
                            <font>
                                <Font size="13.0"/>
                            </font>
                        </Label>

                        <TextField fx:id="txtUsuario"
                                   prefHeight="44.0"
                                   promptText="Ingrese su usuario"
                                   style="-fx-background-color: #FFFFFF;
                                          -fx-background-radius: 9;
                                          -fx-border-color: #CED9E5;
                                          -fx-border-radius: 9;
                                          -fx-padding: 0 14 0 14;
                                          -fx-font-size: 14px;"/>

                    </children>

                </VBox>

                <VBox maxWidth="340.0"
                      spacing="7.0">

                    <children>

                        <Label text="Contraseña"
                               style="-fx-text-fill: #425D75;
                                      -fx-font-weight: bold;">
                            <font>
                                <Font size="13.0"/>
                            </font>
                        </Label>

                        <PasswordField fx:id="txtContrasena"
                                       prefHeight="44.0"
                                       promptText="Ingrese su contraseña"
                                       style="-fx-background-color: #FFFFFF;
                                              -fx-background-radius: 9;
                                              -fx-border-color: #CED9E5;
                                              -fx-border-radius: 9;
                                              -fx-padding: 0 14 0 14;
                                              -fx-font-size: 14px;"/>

                    </children>

                </VBox>

                <Button fx:id="btnIngresar"
                        maxWidth="340.0"
                        prefHeight="46.0"
                        mnemonicParsing="false"
                        onAction="#ingresar"
                        text="Ingresar"
                        style="-fx-background-color: #3F6F96;
                               -fx-background-radius: 9;
                               -fx-text-fill: white;
                               -fx-font-size: 15px;
                               -fx-font-weight: bold;
                               -fx-cursor: hand;
                               -fx-translate-y: 8;"/>

                <HBox alignment="CENTER"
                      maxWidth="340.0"
                      style="-fx-padding: 20 0 0 0;">

                    <children>

                        <Label text="Acceso para administradores, operadores y repartidores"
                               wrapText="true"
                               textAlignment="CENTER"
                               style="-fx-text-fill: #91A0AF;">
                            <font>
                                <Font size="11.0"/>
                            </font>
                        </Label>

                    </children>

                </HBox>

            </children>

        </VBox>

    </children>

</AnchorPane>
