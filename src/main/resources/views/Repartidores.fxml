<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="650.0"
            prefWidth="900.0"
            xmlns="http://javafx.com/javafx/26"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.paqueteria.controller.RepartidorController">

    <children>

        <Label layoutX="250.0"
               layoutY="20.0"
               text="GESTIÓN DE REPARTIDORES">

            <font>
                <Font name="System Bold" size="26.0"/>
            </font>

        </Label>

        <!-- DATOS -->

        <Label layoutX="40.0" layoutY="80.0" text="Cédula"/>
        <TextField fx:id="txtCedula"
                   layoutX="40.0"
                   layoutY="100.0"
                   prefWidth="180"/>

        <Label layoutX="250.0" layoutY="80.0" text="Nombres"/>
        <TextField fx:id="txtNombre"
                   layoutX="250.0"
                   layoutY="100.0"
                   prefWidth="180"/>

        <Label layoutX="470.0" layoutY="80.0" text="Apellidos"/>
        <TextField fx:id="txtApellido"
                   layoutX="470.0"
                   layoutY="100.0"
                   prefWidth="180"/>

        <Label layoutX="680.0" layoutY="80.0" text="Teléfono"/>
        <TextField fx:id="txtTelefono"
                   layoutX="680.0"
                   layoutY="100.0"
                   prefWidth="170"/>

        <Label layoutX="40.0" layoutY="160.0" text="Correo"/>
        <TextField fx:id="txtCorreo"
                   layoutX="40.0"
                   layoutY="180.0"
                   prefWidth="250"/>

        <Label layoutX="330.0" layoutY="160.0" text="Vehículo"/>
        <TextField fx:id="txtVehiculo"
                   layoutX="330.0"
                   layoutY="180.0"
                   prefWidth="170"/>

        <Label layoutX="540.0" layoutY="160.0" text="Placa"/>
        <TextField fx:id="txtPlaca"
                   layoutX="540.0"
                   layoutY="180.0"
                   prefWidth="140"/>

        <Label layoutX="720.0" layoutY="160.0" text="Disponible"/>

        <ComboBox fx:id="cbDisponible"
                  layoutX="720.0"
                  layoutY="180.0"
                  prefWidth="130"/>

        <!-- BOTONES -->

        <Button fx:id="btnGuardar"
                layoutX="80.0"
                layoutY="255.0"
                prefWidth="120"
                text="Guardar"
                onAction="#guardarRepartidor"/>

        <Button fx:id="btnActualizar"
                layoutX="240.0"
                layoutY="255.0"
                prefWidth="120"
                text="Actualizar"
                onAction="#actualizarRepartidor"/>

        <Button fx:id="btnEliminar"
                layoutX="400.0"
                layoutY="255.0"
                prefWidth="120"
                text="Eliminar"
                onAction="#eliminarRepartidor"/>

        <Button fx:id="btnLimpiar"
                layoutX="560.0"
                layoutY="255.0"
                prefWidth="120"
                text="Limpiar"
                onAction="#limpiarCampos"/>

        <Separator layoutX="30.0"
                   layoutY="320.0"
                   prefWidth="840.0"/>

        <!-- TABLA -->

        <TableView fx:id="tablaRepartidores"
                   layoutX="30.0"
                   layoutY="340.0"
                   prefHeight="270.0"
                   prefWidth="840.0">

            <columns>

                <TableColumn fx:id="colId"
                             prefWidth="45"
                             text="ID"/>

                <TableColumn fx:id="colCedula"
                             prefWidth="90"
                             text="Cédula"/>

                <TableColumn fx:id="colNombre"
                             prefWidth="110"
                             text="Nombres"/>

                <TableColumn fx:id="colApellido"
                             prefWidth="110"
                             text="Apellidos"/>

                <TableColumn fx:id="colTelefono"
                             prefWidth="90"
                             text="Teléfono"/>

                <TableColumn fx:id="colCorreo"
                             prefWidth="150"
                             text="Correo"/>

                <TableColumn fx:id="colVehiculo"
                             prefWidth="90"
                             text="Vehículo"/>

                <TableColumn fx:id="colPlaca"
                             prefWidth="70"
                             text="Placa"/>

                <TableColumn fx:id="colDisponible"
                             prefWidth="80"
                             text="Disponible"/>

            </columns>

        </TableView>

    </children>

</AnchorPane>